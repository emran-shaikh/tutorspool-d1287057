{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://yafjkpckhzpkrptmzcms.supabase.co/functions/v1/sitemap" },
    { "source": "/share/blog/:slug", "destination": "https://yafjkpckhzpkrptmzcms.supabase.co/functions/v1/blog-share?slug=:slug" },
    {
      "source": "/blog/:slug",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|WhatsApp|TelegramBot|Discordbot|Pinterest|redditbot|Applebot|embedly|quora link preview|outbrain|vkShare|W3C_Validator|Iframely|skypeuripreview).*" }
      ],
      "destination": "https://yafjkpckhzpkrptmzcms.supabase.co/functions/v1/blog-share?slug=:slug"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
